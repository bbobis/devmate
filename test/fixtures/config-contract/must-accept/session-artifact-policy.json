{
  "schemaVersion": 2,
  "contractVersion": 4,
  "mode": "multi-root",
  "primary": "api",
  "repos": ["api", "ui"],
  "personas": [
    { "persona": "api-dev", "repo": "api", "editableGlobs": ["src/**"], "source": "repo" },
    { "persona": "ui-dev", "repo": "ui", "editableGlobs": ["src/**"], "source": "repo" }
  ],
  "sessionArtifactPaths": [".devmate/state/**", ".devmate/session/**", ".devmate/memory/**"],
  "sessionArtifactWriters": [
    { "glob": ".devmate/session/**/spec.md", "agents": ["spec-writer"] }
  ]
}
